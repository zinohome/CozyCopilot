# CozyCopilot — environment variables example
# Copy to `.env.local` and fill in real values for local development.

# --- CozyEngineV2 upstream ---
# Where the BFF proxies all /v1/* requests.
COZY_ENGINE_URL=http://localhost:8000

# --- Rate limit (requests per 60s window) ---
# Default for all /api/cozy/* routes.
RATE_LIMIT_DEFAULT=60
# Stricter limit for POST /api/cozy/auth to prevent brute-force login.
RATE_LIMIT_LOGIN=5
