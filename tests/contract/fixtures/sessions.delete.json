{
  "version": 1,
  "upstreamRequest": {
    "method": "DELETE",
    "pathname": "/v1/sessions/11111111-1111-4111-8111-111111111101",
    "headers": { "Authorization": "Bearer <any-jwt>" }
  },
  "upstreamResponse": {
    "status": 200,
    "headers": { "Content-Type": "application/json" },
    "body": {
      "id": "11111111-1111-4111-8111-111111111101",
      "deleted": true
    }
  },
  "expectedResponse": {
    "id": "11111111-1111-4111-8111-111111111101",
    "deleted": true
  },
  "errorScenarios": [
    {
      "name": "404 NOT_FOUND when session is gone",
      "upstreamResponse": {
        "status": 404,
        "body": { "code": "NOT_FOUND", "message": "session gone" }
      },
      "expectedError": {
        "code": "NOT_FOUND",
        "status": 404
      }
    }
  ]
}
