    "pathname": "/v1/users/me/providers/66666666-6666-4666-8666-666666666601",
    "headers": { "Authorization": "Bearer <any-jwt>" }
  },
  "upstreamResponse": {
    "status": 200,
    "headers": { "Content-Type": "application/json" },
    "body": {
      "id": "66666666-6666-4666-8666-666666666601",
      "deleted": true
    }
  },
  "expectedResponse": {
    "id": "66666666-6666-4666-8666-666666666601",
    "deleted": true
