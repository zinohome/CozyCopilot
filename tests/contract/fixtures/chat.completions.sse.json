{
  "version": 1,
  "upstreamRequest": {
    "method": "POST",
    "pathname": "/v1/chat/completions",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "Bearer <any-jwt>"
    },
    "body": {
      "session_id": "11111111-1111-4111-8111-111111111101",
      "personality_id": "22222222-2222-4222-8222-222222222201",
      "message": "Hello, world."
    }
  },
  "upstreamResponse": {
    "status": 200,
